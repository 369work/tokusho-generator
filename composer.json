{
    "name": "369work/tokusho-generator",
    "description": "特定商取引法に基づく表示ページを自動生成するPHPライブラリ。ネット販売における決済サービスの審査対応を念頭に設計。",
    "type": "library",
    "keywords": [
        "tokusho",
        "特商法",
        "特定商取引法",
        "stripe",
        "ecommerce",
        "compliance",
        "php"
    ],
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tokusho\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tokusho\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
